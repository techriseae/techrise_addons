<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_techrise_subscription_list" model="ir.ui.view">
        <field name="name">techrise.subscription.list</field>
        <field name="model">techrise.subscription</field>
        <field name="arch" type="xml">
            <list decoration-success="state == 'active'"
                  decoration-muted="state == 'draft'"
                  decoration-warning="state == 'suspended'"
                  decoration-danger="state == 'expired'">
                <field name="state" widget="badge"
                       decoration-success="state == 'active'"
                       decoration-warning="state == 'suspended'"
                       decoration-danger="state == 'expired'"/>
                <field name="name"/>
                <field name="partner_id"/>
                <field name="plan"/>
                <field name="start_date" optional="show"/>
                <field name="end_date" optional="show"/>
                <field name="seats_used"/>
                <field name="seat_count" string="Seats"/>
                <field name="seats_available" optional="show"/>
            </list>
        </field>
    </record>

    <record id="view_techrise_subscription_form" model="ir.ui.view">
        <field name="name">techrise.subscription.form</field>
        <field name="model">techrise.subscription</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_activate" type="object" string="Activate"
                            class="btn-primary"
                            invisible="state == 'active'"/>
                    <button name="action_suspend" type="object" string="Suspend"
                            invisible="state in ('suspended', 'draft')"/>
                    <button name="action_renew" type="object" string="Renew"
                            invisible="state not in ('expired', 'suspended')"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,active,suspended,expired"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="Customer">
                            <field name="partner_id"/>
                            <field name="plan"/>
                        </group>
                        <group string="Validity">
                            <field name="start_date"/>
                            <field name="end_date"/>
                        </group>
                        <group string="Seats">
                            <field name="seat_count"/>
                            <field name="seats_used"/>
                            <field name="seats_available"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Devices" name="devices">
                            <field name="device_ids">
                                <list editable="bottom">
                                    <field name="state" widget="badge"
                                           decoration-success="state == 'active'"
                                           decoration-warning="state == 'pending'"
                                           decoration-danger="state == 'blocked'"/>
                                    <field name="name"/>
                                    <field name="device_uid"/>
                                    <field name="app_id"/>
                                    <field name="last_seen"/>
                                </list>
                            </field>
                        </page>
                        <page string="Notes" name="notes">
                            <field name="note" placeholder="Internal notes..."/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_techrise_subscription_search" model="ir.ui.view">
        <field name="name">techrise.subscription.search</field>
        <field name="model">techrise.subscription</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="partner_id"/>
                <filter name="active" string="Active"
                        domain="[('state', '=', 'active')]"/>
                <filter name="draft" string="Draft"
                        domain="[('state', '=', 'draft')]"/>
                <filter name="expired" string="Expired"
                        domain="[('state', '=', 'expired')]"/>
                <separator/>
                <filter name="expiring_30" string="Expiring (30 days)"
                        domain="[('state', '=', 'active'), ('end_date', '!=', False),
                                 ('end_date', '&lt;=', (context_today() + datetime.timedelta(days=30)).strftime('%Y-%m-%d'))]"/>
                <group expand="0" string="Group By">
                    <filter name="group_state" string="Status"
                            context="{'group_by': 'state'}"/>
                    <filter name="group_partner" string="Customer"
                            context="{'group_by': 'partner_id'}"/>
                    <filter name="group_plan" string="Plan"
                            context="{'group_by': 'plan'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_techrise_subscription" model="ir.actions.act_window">
        <field name="name">Subscriptions</field>
        <field name="res_model">techrise.subscription</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_techrise_subscription_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Create a subscription</p>
            <p>A subscription belongs to a customer and grants a number of device
               seats. Approved devices consume seats; the gate denies them once
               the subscription is suspended or past its expiry date.</p>
        </field>
    </record>

    <menuitem id="menu_techrise_subscriptions" name="Subscriptions"
              parent="menu_techrise_root" action="action_techrise_subscription"
              sequence="5"/>

</odoo>
