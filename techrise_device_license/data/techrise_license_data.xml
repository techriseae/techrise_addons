<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="seq_techrise_subscription" model="ir.sequence">
            <field name="name">Techrise Subscription</field>
            <field name="code">techrise.subscription</field>
            <field name="prefix">SUB/%(year)s/</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>

        <!-- Strict mode: when 'True', a device with no subscription is denied.
             Default 'False' so existing approved devices keep working. -->
        <record id="param_require_subscription" model="ir.config_parameter">
            <field name="key">techrise_license.require_subscription</field>
            <field name="value">False</field>
        </record>

    </data>

    <record id="cron_expire_subscriptions" model="ir.cron">
        <field name="name">Techrise: expire subscriptions past their end date</field>
        <field name="model_id" ref="model_techrise_subscription"/>
        <field name="state">code</field>
        <field name="code">model._cron_expire_subscriptions()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active" eval="True"/>
    </record>

</odoo>
